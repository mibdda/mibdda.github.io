---
---
[
  {% for post in site.posts %}
    {
      "category" : "{{ post.categories | join: ', ' | escape }}",
      "tags"     : "{{ post.tags | join: ', ' | escape }}",
      "url"      : "{{ post.url }}",
      "date"     : "{{ post.date | date: "%Y년 %m월 %d일" }}",
      "content"  : {{ post.content | strip_html | strip_newlines | jsonify }}
    }
    {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
